{
  "name": "@matchina/viz-svg",
  "version": "0.1.0",
  "description": "SVG-based state machine visualizer for Matchina using ELK layout",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --watch"
  },
  "dependencies": {
    "elkjs": "^0.9.3",
    "matchina": "file:../.."
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "unbuild": "^3.6.1"
  }
}
