{
  "name": "@matchina/viz-forcegraph",
  "version": "0.1.0",
  "description": "ForceGraph-based state machine visualizer for Matchina (deprecated)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./utils/shape-to-force-graph": {
      "node": {
        "types": "./src/utils/shape-to-force-graph.ts",
        "import": "./src/utils/shape-to-force-graph.ts"
      },
      "types": "./dist/utils/shape-to-force-graph.d.ts",
      "import": "./dist/utils/shape-to-force-graph.mjs",
      "require": "./dist/utils/shape-to-force-graph.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --watch"
  },
  "dependencies": {
    "force-graph": "^1.51.0",
    "matchina": "file:../.."
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "unbuild": "^3.6.1"
  }
}
