{
  "name": "@matchina/viz-mermaid",
  "version": "0.1.0",
  "description": "Mermaid-based state machine visualizer for Matchina",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --watch"
  },
  "dependencies": {
    "mermaid": "^11.0.0",
    "matchina": "file:../.."
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "unbuild": "^3.6.1"
  }
}
