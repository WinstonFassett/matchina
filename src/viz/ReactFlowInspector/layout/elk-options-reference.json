{
  "algorithms": {
    "layered": {
      "name": "Layered",
      "description": "Layer-based algorithm that arranges nodes in hierarchical layers. Best for state machines and flowcharts.",
      "supportedFeatures": ["selfLoops", "multiEdges", "edgeLabels", "ports", "compound", "clusters"],
      "options": {
        "direction": {
          "key": "org.eclipse.elk.direction",
          "type": "enum",
          "values": ["UP", "DOWN", "LEFT", "RIGHT", "UNDEFINED"],
          "default": "UNDEFINED",
          "description": "Main layout direction. DOWN = top-to-bottom, RIGHT = left-to-right.",
          "impact": "HIGH - Changes entire layout orientation",
          "tooltip": "Choose the primary direction edges should flow. DOWN for traditional top-down state machines, RIGHT for left-to-right flowcharts."
        },
        "spacing": {
          "nodeNode": {
            "key": "org.eclipse.elk.spacing.nodeNode",
            "type": "double",
            "default": 20,
            "min": 0,
            "max": 200,
            "description": "Spacing between nodes in the same layer",
            "impact": "HIGH - Directly affects node spacing",
            "tooltip": "Horizontal spacing for LEFT/RIGHT layouts, vertical spacing for UP/DOWN layouts"
          },
          "edgeNode": {
            "key": "org.eclipse.elk.spacing.edgeNode",
            "type": "double",
            "default": 10,
            "min": 0,
            "max": 100,
            "description": "Spacing between edges and nodes",
            "impact": "MEDIUM - Affects edge-to-node clearance",
            "tooltip": "Distance between edges and nearby nodes. Increase for better edge visibility."
          },
          "edgeEdge": {
            "key": "org.eclipse.elk.spacing.edgeEdge",
            "type": "double",
            "default": 10,
            "min": 0,
            "max": 100,
            "description": "Spacing between parallel edges",
            "impact": "MEDIUM - Affects multi-edge spacing",
            "tooltip": "Distance between multiple edges running parallel. Important for bidirectional transitions."
          }
        },
        "layered": {
          "nodeNodeBetweenLayers": {
            "key": "org.eclipse.elk.layered.spacing.nodeNodeBetweenLayers",
            "type": "double",
            "default": 20,
            "min": 0,
            "max": 200,
            "description": "Vertical spacing between layers",
            "impact": "HIGH - Controls layer separation",
            "tooltip": "Distance between horizontal layers. Critical for readable hierarchical layouts."
          },
          "edgeNodeBetweenLayers": {
            "key": "org.eclipse.elk.layered.spacing.edgeNodeBetweenLayers",
            "type": "double",
            "default": 10,
            "min": 0,
            "max": 100,
            "description": "Spacing between edges and nodes across layers",
            "impact": "MEDIUM - Edge-to-node spacing across layers",
            "tooltip": "Additional spacing for edges crossing between layers. Helps with edge clarity."
          }
        },
        "edgeRouting": {
          "key": "org.eclipse.elk.edgeRouting",
          "type": "enum",
          "values": ["ORTHOGONAL", "POLYLINE", "SPLINES", "STRAIGHT", "UNDEFINED"],
          "default": "ORTHOGONAL",
          "description": "Edge routing style",
          "impact": "HIGH - Changes edge appearance dramatically",
          "tooltip": "ORTHOGONAL = Manhattan-style edges, SPLINES = curved edges, STRAIGHT = direct lines"
        },
        "alignment": {
          "key": "org.eclipse.elk.alignment",
          "type": "enum",
          "values": ["LEFT", "RIGHT", "CENTER", "TOP", "BOTTOM", "AUTOMATIC"],
          "default": "AUTOMATIC",
          "description": "Node alignment within layers",
          "impact": "MEDIUM - Affects node positioning",
          "tooltip": "How nodes are aligned within each layer. CENTER usually looks best."
        },
        "feedbackEdges": {
          "key": "org.eclipse.elk.layered.feedbackEdges",
          "type": "boolean",
          "default": false,
          "description": "Enable feedback edges (edges going backwards)",
          "impact": "HIGH - Allows backward edges",
          "tooltip": "Enable to show edges that go against the main direction. Creates loops in the layout."
        }
      }
    }
  },
  "recommendations": {
    "stateMachines": {
      "algorithm": "layered",
      "direction": "DOWN",
      "spacing": {
        "nodeNode": 30,
        "nodeNodeBetweenLayers": 50,
        "edgeNode": 15
      },
      "edgeRouting": "ORTHOGONAL",
      "alignment": "CENTER",
      "feedbackEdges": true
    },
    "flowcharts": {
      "algorithm": "layered",
      "direction": "RIGHT",
      "spacing": {
        "nodeNode": 40,
        "nodeNodeBetweenLayers": 60,
        "edgeNode": 20
      },
      "edgeRouting": "POLYLINE",
      "alignment": "CENTER"
    },
    "compactLayouts": {
      "algorithm": "layered",
      "spacing": {
        "nodeNode": 15,
        "nodeNodeBetweenLayers": 25,
        "edgeNode": 8
      }
    },
    "spaciousLayouts": {
      "algorithm": "layered",
      "spacing": {
        "nodeNode": 50,
        "nodeNodeBetweenLayers": 80,
        "edgeNode": 25
      }
    }
  },
  "implementationNotes": {
    "criticalOptions": [
      "org.eclipse.elk.direction",
      "org.eclipse.elk.spacing.nodeNode",
      "org.eclipse.elk.layered.spacing.nodeNodeBetweenLayers",
      "org.eclipse.elk.edgeRouting"
    ],
    "reliableOptions": [
      "org.eclipse.elk.spacing.edgeNode",
      "org.eclipse.elk.spacing.edgeEdge",
      "org.eclipse.elk.alignment",
      "org.eclipse.elk.aspectRatio"
    ],
    "avoidThese": [
      "org.eclipse.elk.debugMode",
      "org.eclipse.elk.layered.thoroughness",
      "org.eclipse.elk.layered.crossingMinimization.strategy",
      "org.eclipse.elk.layered.nodePlacement.strategy"
    ]
  }
}
