---
import { Code, Tabs, TabItem } from "@astrojs/starlight/components";
import { ExamplePreview } from "./ExamplePreview";
import { getExample } from "../examples";
import { runElkLayout, type SvgLayout } from "@matchina/viz-svg";

interface Props {
  id: string;
  /** Link to the full standalone viewer */
  viewerLink?: boolean;
  /**
   * Hide the Preview/Code tab bar and render only the preview.
   * Use when the article narrates code separately via <ExampleCode>,
   * so the same source isn't shown twice.
   */
  previewOnly?: boolean;
}

const { id, viewerLink = true, previewOnly = false } = Astro.props as Props;

const meta = getExample(id);
const sourceFiles = meta ? await meta.getSourceFiles() : [];

// Compute the SVG layout at build time so the React tree can SSR the diagram
// — no skeleton flash, no "computing layout…" placeholder on first paint.
// Keep options in sync with MachineVisualizer's defaults (direction: DOWN, etc.)
// so the post-mount effect doesn't trigger a re-layout with different params.
let precomputedLayout: SvgLayout | undefined;
if (meta && meta.kind !== "store") {
  try {
    const m = meta.machineFactory();
    const shape = (m as any).shape?.getState?.();
    if (shape) {
      precomputedLayout = await runElkLayout(shape, {
        direction: "DOWN",
        nodeSpacing: 40,
        layerSpacing: 60,
      });
    }
  } catch (err) {
    console.warn(`[ExampleEmbed] precompute layout failed for "${id}":`, err);
  }
}

function getLang(filename: string): string {
  const ext = filename.split(".").pop();
  switch (ext) {
    case "ts": return "ts";
    case "tsx": return "tsx";
    case "js": return "javascript";
    case "jsx": return "jsx";
    default: return "plaintext";
  }
}

// Per-instance unique id so multiple embeds on a page don't share radio groups.
const uid = `embed-${id}-${Math.random().toString(36).slice(2, 8)}`;
---

{!meta && (
  <p class="font-mono text-sm text-red-500">Example "{id}" not found</p>
)}

{meta && (
  <div class="example-embed not-content" data-preview-only={previewOnly ? "" : undefined}>
    {!previewOnly && (
      <>
        {/* No-JS progressive tabs: radio inputs drive panel visibility via :has(input:checked) */}
        <input type="radio" name={uid} id={`${uid}-preview`} class="example-embed-radio" checked />
        <input type="radio" name={uid} id={`${uid}-code`} class="example-embed-radio" />

        <div class="example-embed-tabs-bar" role="tablist">
          {viewerLink && (
            <a
              href={`/matchina/examples/${id}`}
              class="example-embed-viewer-link"
              title="Open in standalone viewer"
            >
              open in viewer →
            </a>
          )}
          <label
            for={`${uid}-preview`}
            class="example-embed-tab"
            data-tab="preview"
            role="tab"
            style="margin-left: auto"
          >
            Preview
          </label>
          <label
            for={`${uid}-code`}
            class="example-embed-tab"
            data-tab="code"
            role="tab"
          >
            Code
          </label>
        </div>
      </>
    )}
    {previewOnly && viewerLink && (
      <div class="example-embed-tabs-bar" role="tablist">
        <a
          href={`/matchina/examples/${id}`}
          class="example-embed-viewer-link"
          title="Open in standalone viewer"
          style="margin-left: auto"
        >
          open in viewer →
        </a>
      </div>
    )}

    <div class="example-embed-panel example-embed-panel--preview" data-panel="preview">
      <ExamplePreview id={id} precomputedLayout={precomputedLayout} client:load />
    </div>

    {!previewOnly && (
      <div class="example-embed-panel example-embed-panel--code" data-panel="code">
        {sourceFiles.length === 1 && (
          <Code code={sourceFiles[0].code} lang={getLang(sourceFiles[0].name)} />
        )}
        {sourceFiles.length > 1 && (
          <Tabs>
            {sourceFiles.map((f) => (
              <TabItem label={f.name}>
                <Code code={f.code} lang={getLang(f.name)} />
              </TabItem>
            ))}
          </Tabs>
        )}
      </div>
    )}
  </div>
)}

<style>
  .example-embed {
    border: 1px solid hsl(var(--border));
    margin: 1.5rem 0;
  }

  /* Hide the radio inputs that drive tab state */
  .example-embed-radio {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .example-embed-tabs-bar {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid hsl(var(--border));
    padding: 0 1rem;
  }

  .example-embed-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: hsl(var(--muted-foreground));
    padding: 8px 12px 6px;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
    text-transform: uppercase;
    user-select: none;
  }
  .example-embed-tab:hover { color: hsl(var(--foreground)); }

  /* Active tab styling via :has() — only matches when the corresponding radio is checked */
  .example-embed:has(.example-embed-radio:nth-of-type(1):checked) [data-tab="preview"],
  .example-embed:has(.example-embed-radio:nth-of-type(2):checked) [data-tab="code"] {
    color: hsl(var(--foreground));
    border-bottom-color: hsl(var(--foreground));
  }

  /* Focus ring for keyboard navigation */
  .example-embed:has(.example-embed-radio:nth-of-type(1):focus-visible) [data-tab="preview"],
  .example-embed:has(.example-embed-radio:nth-of-type(2):focus-visible) [data-tab="code"] {
    outline: 2px solid hsl(var(--ring));
    outline-offset: 2px;
  }

  .example-embed-viewer-link {
    margin-left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    padding: 8px 4px;
    transition: color 0.15s;
  }
  .example-embed-viewer-link:hover { color: hsl(var(--foreground)); }

  .example-embed-panel {
    padding: 1.25rem;
    display: none;
    flex-direction: column;
    height: 500px;
    overflow: auto;
  }
  /* Show the panel whose radio is checked. preview-only embeds (no radios) fall back to showing preview. */
  .example-embed:has(.example-embed-radio:nth-of-type(1):checked) [data-panel="preview"],
  .example-embed:has(.example-embed-radio:nth-of-type(2):checked) [data-panel="code"],
  .example-embed[data-preview-only] [data-panel="preview"] {
    display: flex;
  }
</style>
