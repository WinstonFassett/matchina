---
import { TabItem, Tabs, Code } from "@astrojs/starlight/components";

interface Props {
  files: {
    name: string;
    code: string;
    language: string;
    twoslash?: boolean;
  }[];
}

const { files } = Astro.props as Props;

function getLangFromExtension(filename: string): string {
  const ext = filename.split(".").pop();
  switch (ext) {
    case "ts":
      return "ts";
    case "js":
      return "javascript";
    case "jsx":
      return "jsx";
    case "tsx":
      return "tsx";
    case "py":
      return "python";
    default:
      return "plaintext";
  }
}
---

<Tabs>
  {
    files.map((file) => (
      <TabItem label={file.name}>
        <Code
          code={file.code}
          lang={file.language ?? getLangFromExtension(file.name)}
          meta={file.twoslash ? 'twoslash' : undefined}
        />
      </TabItem>
    ))
  }
</Tabs>
