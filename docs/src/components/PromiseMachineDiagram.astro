---
import { MermaidInspector } from "@matchina/viz-mermaid";
import { buildVisualizerTree } from "@code/examples/lib/matchina-machine-to-xstate-definition";
import { eventApi, createPromiseMachine, delay, type FactoryMachine } from "matchina";

const machine = createPromiseMachine(async (_message: string) => await delay(1000))
const config = buildVisualizerTree(machine as FactoryMachine<any>)
const actions = eventApi(machine)
---

<MermaidInspector shape={config} currentStateKey={machine.getState().key} actions={actions} interactive={true} diagramType="statechart" client:only="react" />