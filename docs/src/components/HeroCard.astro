  <div class="pane-left">
    <div class="pane-head">
      <span>fig.01 — fetcher machine</span>
      <span class="live-dot">● live</span>
    </div>
    <svg viewBox="0 0 460 200" width="100%" height="200" style="overflow:visible">
      <!-- grid dots -->
      <circle cx="20" cy="20" r="0.7" fill="var(--border)" />
      <circle cx="80" cy="20" r="0.7" fill="var(--border)" />
      <circle cx="140" cy="20" r="0.7" fill="var(--border)" />
