      <circle cx="380" cy="170" r="0.7" fill="var(--border)" />
      <circle cx="440" cy="170" r="0.7" fill="var(--border)" />
      <!-- edges -->
      <line x1="118" y1="58" x2="165" y2="58" stroke="var(--accent)" stroke-width="1.5" />
      <polygon points="165,58 159,55 159,61" fill="var(--accent)" />
      <line x1="266" y1="50" x2="316" y2="34" stroke="var(--accent)" stroke-width="1.5" />
      <polygon points="316,34 310,33 312,39" fill="var(--accent)" />
      <line x1="266" y1="66" x2="316" y2="126" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="3 3" />
      <polygon points="316,126 310,122 309,128" fill="var(--border)" />
      <path d="M 316 140 Q 220 170 180 86" stroke="var(--border)" fill="none" stroke-width="1.5" stroke-dasharray="3 3" />
      <polygon points="180,86 182,92 186,88" fill="var(--border)" />
      <!-- edge labels -->
      <text x="128" y="50" font-size="9" font-family="var(--font-mono)" fill="var(--muted-foreground)">fetch()</text>
      <text x="270" y="38" font-size="9" font-family="var(--font-mono)" fill="var(--muted-foreground)">resolve</text>
      <text x="270" y="98" font-size="9" font-family="var(--font-mono)" fill="var(--text-mute)">reject</text>
      <text x="210" y="162" font-size="9" font-family="var(--font-mono)" fill="var(--text-mute)">retry</text>
