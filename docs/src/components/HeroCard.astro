      <circle cx="440" cy="70" r="0.7" fill="var(--border)" />
      <circle cx="20" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="80" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="140" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="200" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="260" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="320" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="380" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="440" cy="120" r="0.7" fill="var(--border)" />
      <circle cx="20" cy="170" r="0.7" fill="var(--border)" />
      <circle cx="80" cy="170" r="0.7" fill="var(--border)" />
      <circle cx="140" cy="170" r="0.7" fill="var(--border)" />
      <circle cx="200" cy="170" r="0.7" fill="var(--border)" />
      <circle cx="260" cy="170" r="0.7" fill="var(--border)" />
