---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getExamples } from "../../examples";
import type { ExampleCategory } from "../../examples/types";

const CATEGORY_ORDER: ExampleCategory[] = ["Basic", "Stopwatch", "Async", "Fetcher", "Hierarchical", "Advanced"];

const all = getExamples({ indexable: true });

const categories = CATEGORY_ORDER.map((cat) => ({
  category: cat,
  examples: all.filter((e) => e.category === cat),
})).filter((g) => g.examples.length > 0);
---

<StarlightPage
  frontmatter={{
    title: "Examples",
    description: "Interactive state machine examples built with Matchina.",
    template: "splash",
    hero: {},
  }}
>
  <div class="examples-index not-content">
    <section class="mb-10">
      <p class="text-base text-muted-foreground max-w-2xl">
        Browse interactive examples demonstrating Matchina patterns — from simple toggles to complex hierarchical machines.
      </p>
    </section>

    {categories.map(({ category, examples }) => (
      <section class="mb-10">
        <header class="mb-4 flex items-baseline gap-4 border-b border-border pb-2">
          <h2 class="font-serif text-xl font-medium tracking-tight">{category}</h2>
          <span class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
            {examples.length} example{examples.length === 1 ? "" : "s"}
          </span>
        </header>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {examples.map((ex) => (
            <a href={`/matchina/examples/${ex.id}`} class="ex-card border border-border bg-card p-5 flex flex-col">
              <div class="font-medium text-foreground mb-1">{ex.title}</div>
              <div class="text-sm text-muted-foreground leading-relaxed mb-3">{ex.description}</div>
              {ex.tags && ex.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mb-4">
                  {ex.tags.map((tag) => (
                    <span class="font-mono text-[10px] px-1.5 py-0.5 bg-muted text-muted-foreground">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              <div class="mt-auto flex items-center gap-3">
                {ex.docSlug && (
                  <a
                    href={`/matchina/${ex.docSlug}`}
                    class="ex-cta-secondary"
                    onclick="event.stopPropagation()"
                  >
                    Article →
                  </a>
                )}
                <span class="ex-cta-primary">Playground →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</StarlightPage>

<style>
  .ex-card {
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .ex-card:hover { border-color: hsl(var(--foreground) / 0.4); }

  .ex-cta-primary {
    font-size: 12.5px;
    font-weight: 500;
    color: hsl(var(--foreground));
    margin-left: auto;
  }

  .ex-cta-secondary {
    font-size: 11.5px;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.15s;
  }
  .ex-cta-secondary:hover { color: hsl(var(--foreground)); }
</style>
