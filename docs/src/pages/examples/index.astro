---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getExamples } from "../../examples";
import type { ExampleCategory } from "../../examples/types";

const CATEGORY_ORDER: ExampleCategory[] = ["Basic", "Stopwatch", "Async", "Fetcher", "Hierarchical", "Advanced"];

const all = getExamples({ indexable: true });

const categories = CATEGORY_ORDER.map((cat) => ({
  category: cat,
  examples: all.filter((e) => e.category === cat),
})).filter((g) => g.examples.length > 0);

// Categories where examples are variations on one theme
const VARIANT_CATEGORIES: ExampleCategory[] = ["Stopwatch"];
---

<StarlightPage
  frontmatter={{
    title: "Examples",
    description: "Interactive state machine examples built with Matchina.",
    template: "splash",
    hero: {},
  }}
>
  <div class="ex-index">

    <!-- Hero -->
    <div class="ex-hero">
      <h1 class="ex-hero-headline">State machines<br/><em>in the wild.</em></h1>
      <p class="ex-hero-body">
        Interactive examples built with Matchina. Each opens a live playground with source, visualizer, and article.
      </p>
    </div>

    <!-- Category jump links -->
    <nav class="ex-nav" aria-label="Jump to category">
      {categories.map(({ category, examples }) => (
        <a href={`#cat-${category.toLowerCase()}`} class="ex-nav-link">
          {category}
          <span class="ex-nav-count">{examples.length}</span>
        </a>
      ))}
    </nav>

    <!-- Category sections -->
    {categories.map(({ category, examples }) => {
      const isVariants = VARIANT_CATEGORIES.includes(category);
      return (
        <section class="ex-section" id={`cat-${category.toLowerCase()}`}>
          <h2 class="ex-section-title">{category}</h2>

          {isVariants ? (
            <ol class="ex-list">
              {examples.map((ex, i) => (
                <li class="ex-list-row">
                  <span class="ex-list-num">{String(i + 1).padStart(2, "0")}</span>
                  <div class="ex-list-body">
                    <a href={`/matchina/examples/${ex.id}`} class="ex-list-title">{ex.title}</a>
                    <span class="ex-list-desc">{ex.description}</span>
                  </div>
                  <div class="ex-list-actions">
                    {ex.docSlug && (
                      <a href={`/matchina/${ex.docSlug}`} class="ex-link-muted">Article</a>
                    )}
                    <a href={`/matchina/examples/${ex.id}`} class="ex-link-open">Open →</a>
                  </div>
                </li>
              ))}
            </ol>
          ) : (
            <div class="ex-grid">
              {examples.map((ex, i) => (
                <div class={`ex-card${examples.length % 2 !== 0 && i === examples.length - 1 ? " ex-card-span" : ""}`} data-href={`/matchina/examples/${ex.id}`} role="link" tabindex="0">
                  <div class="ex-card-body">
                    <div class="ex-card-title">{ex.title}</div>
                    <div class="ex-card-desc">{ex.description}</div>
                  </div>
                  <div class="ex-card-foot">
                    {ex.docSlug && (
                      <a href={`/matchina/${ex.docSlug}`} class="ex-link-muted">Article</a>
                    )}
                    <a href={`/matchina/examples/${ex.id}`} class="ex-link-open">Open →</a>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>
      );
    })}

  </div>
</StarlightPage>

<script>
  // Make entire card clickable without nesting anchors
  document.querySelectorAll<HTMLElement>(".ex-card[data-href]").forEach((card) => {
    card.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) return;
      window.location.href = card.dataset.href!;
    });
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        window.location.href = card.dataset.href!;
      }
    });
  });
</script>

<style>
  /* ── Hide Starlight chrome we don't want ────────────────── */
  :global(.hero) { display: none !important; }
  :global(.pagination-links) { display: none !important; }

  /* ── Layout ─────────────────────────────────────────────── */

  .ex-index {
    padding: 0 0 80px;
  }

  /* ── Hero ───────────────────────────────────────────────── */

  .ex-hero {
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }

  .ex-hero-headline {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--foreground);
    margin: 0 0 16px;
  }

  .ex-hero-headline em {
    font-style: italic;
    color: var(--muted-foreground);
  }

  .ex-hero-body {
    font-family: var(--font-sans);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--muted-foreground);
    max-width: 56ch;
    margin: 0;
  }

  /* ── Category nav ───────────────────────────────────────── */

  .ex-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 2px;
    margin-bottom: 52px;
  }

  .ex-nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--muted-foreground);
    text-decoration: none;
    padding: 4px 10px;
    border: 1px solid var(--border);
    transition: color 0.12s, border-color 0.12s;
  }

  .ex-nav-link:hover {
    color: var(--foreground);
    border-color: var(--foreground);
  }

  .ex-nav-count {
    font-family: var(--font-mono);
    font-size: 9px;
    opacity: 0.6;
  }

  /* ── Section ────────────────────────────────────────────── */

  .ex-section {
    margin-bottom: 56px;
    scroll-margin-top: 80px;
  }

  .ex-section-title {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--foreground);
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }

  /* ── Grid cards ─────────────────────────────────────────── */

  .ex-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    align-items: stretch;
  }

  .ex-card-span { grid-column: 1 / -1; }

  @media (max-width: 600px) {
    .ex-grid { grid-template-columns: 1fr; }
  }

  .ex-card {
    background: var(--background);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    padding: 20px 22px;
    transition: background 0.1s;
    outline: none;
    align-self: stretch;
    margin: 0 !important;
  }

  .ex-grid {
    align-items: stretch;
  }

  .ex-card:hover,
  .ex-card:focus-visible {
    background: var(--muted);
  }

  .ex-card-body {
    flex: 1 1 0% !important;
    margin-bottom: 16px;
    margin-top: 0 !important;
  }

  .ex-card-title {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: 5px;
    line-height: 1.3;
  }

  .ex-card-desc {
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.5;
    color: var(--muted-foreground);
  }

  .ex-card-foot {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    margin-top: 0 !important;
  }

  /* ── Variant list ───────────────────────────────────────── */

  .ex-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ex-list-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }

  .ex-list-num {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted-foreground);
    min-width: 20px;
    flex-shrink: 0;
    opacity: 0.45;
  }

  .ex-list-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ex-list-title {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--foreground);
    text-decoration: none;
    transition: color 0.12s;
  }

  .ex-list-title:hover {
    color: var(--accent);
  }

  .ex-list-desc {
    font-family: var(--font-sans);
    font-size: 11.5px;
    color: var(--muted-foreground);
    line-height: 1.4;
  }

  .ex-list-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }

  /* ── Shared link styles ─────────────────────────────────── */

  .ex-link-muted {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.12s;
    opacity: 0.7;
  }

  .ex-link-muted:hover {
    color: var(--accent);
    opacity: 1;
  }

  .ex-link-open {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.12s;
    margin-left: auto;
  }

  .ex-link-open:hover {
    color: var(--foreground);
  }

  .ex-card-foot .ex-link-open {
    margin-left: auto;
  }
</style>
