---
import CdnDemoLayout from "@/layouts/CdnDemoLayout.astro";
import { matchinaVersion, cdnUrls } from "@/lib/matchina-version";
const jsdelivrUrl = cdnUrls.jsdelivr;
const sourceNote = `cdn.jsdelivr.net/npm/matchina@${matchinaVersion}/+esm · one request, full bundle`;
---
<CdnDemoLayout
    title="Matchina via jsDelivr +esm"
    eyebrow="Matchina · CDN demo · jsDelivr"
    headline="One request from"
    headlineAccent="jsDelivr"
    sourceNote={sourceNote}
>
    <article class="card">
        <div class="card-eyebrow"><span>fig.01 — Traffic light</span><span class="meta">matchina</span></div>
        <div class="card-stage">
            <div class="traffic">
                <div class="light" id="red"></div>
                <div class="light" id="yellow"></div>
                <div class="light" id="green"></div>
            </div>
        </div>
        <p class="state-line">state <code id="tl-state">Red</code></p>
        <div class="row">
            <button id="tl-next">Next →</button>
            <button id="tl-reset" class="secondary">Reset</button>
        </div>
        <footer><span class="log" id="tl-log">waiting…</span></footer>
    </article>

    <article class="card">
        <div class="card-eyebrow"><span>fig.02 — Counter store</span><span class="meta">createStore</span></div>
        <div class="card-stage">
            <p class="count" id="counter-value">0</p>
        </div>
        <div class="row">
            <button id="cnt-dec-5" class="secondary">−5</button>
            <button id="cnt-dec" class="secondary">−1</button>
            <button id="cnt-inc">+1</button>
            <button id="cnt-inc-5">+5</button>
        </div>
        <div class="row">
            <button id="cnt-set" class="outline">Set 100</button>
            <button id="cnt-reset" class="outline">Reset</button>
        </div>
        <footer><span class="log" id="cnt-log">waiting…</span></footer>
    </article>

    <script slot="scripts" type="module" define:vars={{ jsdelivrUrl }}>
        const { matchina, defineStates, createStore } = await import(jsdelivrUrl);

        const states = defineStates({ Red: undefined, Yellow: undefined, Green: undefined });
        const traffic = matchina(
            states,
            {
                Red:    { next: 'Green',  reset: 'Red' },
                Green:  { next: 'Yellow', reset: 'Red' },
                Yellow: { next: 'Red',    reset: 'Red' },
            },
            'Red'
        );

        const tlState = document.getElementById('tl-state');
        const tlLog = document.getElementById('tl-log');
        const lights = { Red: document.getElementById('red'), Yellow: document.getElementById('yellow'), Green: document.getElementById('green') };
        function paintTraffic() {
            const key = traffic.getState().key;
            tlState.textContent = key;
            for (const k of Object.keys(lights)) {
                lights[k].className = `light ${k === key ? k.toLowerCase() : ''}`;
            }
        }
        traffic.subscribe(ev => {
            paintTraffic();
            tlLog.textContent = `${ev.from.key} → ${ev.to.key}`;
        });
        paintTraffic();
        document.getElementById('tl-next').onclick  = () => traffic.next();
        document.getElementById('tl-reset').onclick = () => traffic.reset();

        const counter = createStore(0, {
            increment: (amt = 1) => (ch) => ch.from + amt,
            decrement: (amt = 1) => (ch) => ch.from - amt,
            set: (value) => value,
            reset: () => 0,
        });
        const cntValue = document.getElementById('counter-value');
        const cntLog = document.getElementById('cnt-log');
        counter.subscribe(ev => {
            cntValue.textContent = counter.getState();
            cntLog.textContent = `${ev.from} → ${ev.to}`;
        });
        cntValue.textContent = counter.getState();
        document.getElementById('cnt-inc').onclick   = () => counter.increment();
        document.getElementById('cnt-dec').onclick   = () => counter.decrement();
        document.getElementById('cnt-inc-5').onclick = () => counter.increment(5);
        document.getElementById('cnt-dec-5').onclick = () => counter.decrement(5);
        document.getElementById('cnt-set').onclick   = () => counter.set(100);
        document.getElementById('cnt-reset').onclick = () => counter.reset();

        window.traffic = traffic;
        window.counter = counter;
    </script>
</CdnDemoLayout>
