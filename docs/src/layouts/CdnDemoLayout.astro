---
interface Props {
    title: string;
    eyebrow: string;
    headline: string;
    headlineAccent?: string;
    sourceNote: string;
}
const { title, eyebrow, headline, headlineAccent, sourceNote } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&family=Source+Serif+4:ital,wght@0,400;0,500;1,400;1,500&display=swap">
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}cdn-demos/demo.css`}>
</head>
<body>
    <main class="container">
        <p class="eyebrow">{eyebrow}</p>
        <h1>{headline} {headlineAccent && <em>{headlineAccent}</em>}</h1>
        <p class="subtitle">{sourceNote}</p>

        <div class="grid">
            <slot />
        </div>

    </main>
    <slot name="scripts" />
</body>
</html>
