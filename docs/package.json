    "immer": "^10.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "matchina": "file:..",
    "mdast-util-to-hast": "^13.2.1",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reactflow": "^11.11.4",
    "sharp": "^0.34.2",
