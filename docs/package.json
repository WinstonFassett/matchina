    "@astrojs/starlight-tailwind": "^4.0.1",
    "@matchina/viz-forcegraph": "file:../packages/viz-forcegraph",
    "@matchina/viz-react": "file:../packages/viz-react",
    "@matchina/viz-svg": "file:../packages/viz-svg",
    "@tailwindcss/vite": "^4.0.7",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.10.0",
    "astro": "^6.3.3",
    "astro-remote": "^0.3.4",
    "clsx": "^2.1.1",
    "elkjs": "^0.10.2",
    "expressive-code-twoslash": "^0.6.1",
    "force-graph": "^1.51.0",
