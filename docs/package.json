{
  "name": "docs",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "postinstall": "[ \"$ENABLE_TYPEDOC\" = \"1\" ] && npm run build:typedoc-plugin || true",
    "dev": "portless matchina-docs astro dev",
    "dev:pdf": "npx starlight-to-pdf http://localhost:4321",
    "start": "portless matchina-docs astro dev",
    "check": "astro check",
    "build:typedoc-plugin": "node scripts/build-typedoc-plugin.mjs",
    "watch:typedoc-plugin": "node scripts/build-typedoc-plugin.mjs --watch",
    "prebuild": "[ \"$ENABLE_TYPEDOC\" = \"1\" ] && npm run build:typedoc-plugin || true",
    "build": "rm -rf dist && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/ts-plugin": "^1.10.4",
