{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*", "scripts/**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@code/*": ["src/code/*"],
      "@lib/*": ["../*"],
      "matchina": ["../src/index.ts"],
      "matchina/*": ["../src/*"],
      "matchina/react": ["../src/integrations/react"],
      "matchina/hsm": ["../src/hsm/index.ts"],
      "@matchina/viz-reactflow": ["../packages/viz-reactflow/src/index.ts"],
      "@matchina/viz-mermaid": ["../packages/viz-mermaid/src/index.ts"],
      "@matchina/viz-forcegraph": ["../packages/viz-forcegraph/src/index.ts"],
      "@matchina/viz-react": ["../packages/viz-react/src/index.ts"],
      "@matchina/viz-svg": ["../packages/viz-svg/src/index.ts"]
    }
  }
}
